    create or replace table `dtc-course-486211`.`crypto_project1`.`top_10_crypto`
      
    
    

    
    OPTIONS()
    as (
      with base as (

    select *
    from `dtc-course-486211`.`crypto_project1`.`stg_crypto`
    where market_cap_rank <= 10

),

latest_timestamp as (

    select max(timestamp_hour) as max_ts
    from base

)

select
    b.timestamp_hour,
    b.coin_id,
    b.name,
    b.symbol,
    b.current_price,
    b.market_cap,
    b.total_volume,
    b.price_change_percentage_24h,
    b.market_cap_rank

from base b
join latest_timestamp t
    on b.timestamp_hour = t.max_ts
    );
  
